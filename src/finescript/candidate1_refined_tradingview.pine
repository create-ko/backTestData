//@version=5
strategy(
     "XAUUSD Candidate 1 Refined - TV Port",
     overlay=true,
     initial_capital=100000,
     currency=currency.USD,
     pyramiding=3,
     commission_type=strategy.commission.cash_per_contract,
     commission_value=0.5,
     process_orders_on_close=false,
     calc_on_every_tick=false,
     max_labels_count=500,
     max_lines_count=500)

// Candidate 1 refined TradingView port.
//
// Authoritative research result is generated by:
//   src/scripts/98_candidate1_refined_full_backtest.py
//
// Important TradingView limitation:
// Python combines three precomputed signal streams from 5m, 15m-derived, and 2m data,
// then deduplicates same-time/same-direction trades. Pine cannot read those CSV trades.
// This file therefore implements the same rule family directly on chart data, intended
// for chart-side backtesting and manual inspection. For closest behavior, run it on
// XAUUSD 5m CFD data with Asia/Seoul exchange time interpretation.

// ---------- Inputs ----------
groupRegime = "Monthly regime"
ret20Min = input.float(0.0084, "ret20 minimum", step=0.0001, group=groupRegime)
ret240Min = input.float(-0.0428, "ret240 minimum", step=0.0001, group=groupRegime)
adr20Min = input.float(18.0, "ADR20 minimum, points", step=0.1, group=groupRegime)

groupRisk = "Risk controls"
dayStop = input.float(50.0, "KST daily stop, points", step=1.0, group=groupRisk)
allowSession = input.bool(true, "Enable session retest component", group=groupRisk)
allowGrid = input.bool(true, "Enable grid component", group=groupRisk)
allowOnebee = input.bool(true, "Enable Onebee component", group=groupRisk)

groupGrid = "Grid component"
gridStartHour = input.int(9, "Grid start hour KST", minval=0, maxval=23, group=groupGrid)
gridEndHour = input.int(18, "Grid end hour KST", minval=1, maxval=24, group=groupGrid)
pendingBars = input.int(10, "Grid pending bars", minval=1, maxval=30, group=groupGrid)
gridStep = input.float(10.0, "Grid step", step=0.1, group=groupGrid)
gridStop = input.float(35.0, "Grid stop from entry 1", step=0.1, group=groupGrid)
gridArm = input.float(10.0, "Grid trail arm", step=0.1, group=groupGrid)
gridTrail = input.float(10.0, "Grid trail points", step=0.1, group=groupGrid)
gridRecovery = input.float(3.0, "Third-fill recovery points", step=0.1, group=groupGrid)

groupSession = "Session component"
rr = input.float(2.0, "Session target R", step=0.1, group=groupSession)
bodyMin = input.float(0.90, "Breakout body ratio minimum", minval=0.0, maxval=1.0, step=0.05, group=groupSession)

groupOnebee = "Onebee component"
onebeeAtrLen = input.int(30, "Onebee KTR proxy ATR length", minval=2, group=groupOnebee)
onebeeTargetKtr = input.float(2.0, "Onebee target KTR", step=0.1, group=groupOnebee)
onebeeStopKtr = input.float(5.5, "Onebee stop KTR", step=0.1, group=groupOnebee)

groupReport = "Report"
showReport = input.bool(true, "Show yearly/monthly report tables", group=groupReport)
monthRows = input.int(18, "Monthly rows to show", minval=6, maxval=40, group=groupReport)

var int[] yearKeys = array.new_int()
var float[] yearPnl = array.new_float()
var int[] yearTrades = array.new_int()
var int[] monthKeys = array.new_int()
var float[] monthPnl = array.new_float()
var int[] monthTrades = array.new_int()

// ---------- Helpers ----------
f_kstHour() => hour(time, "Asia/Seoul")
f_kstMinute() => minute(time, "Asia/Seoul")
f_kstYear() => year(time, "Asia/Seoul")
f_kstMonth() => month(time, "Asia/Seoul")
f_kstDay() => dayofmonth(time, "Asia/Seoul")
f_inKstHours(startHour, endHour) =>
    h = f_kstHour()
    startHour < endHour ? h >= startHour and h < endHour : h >= startHour or h < endHour

f_bodyRatio() =>
    rng = high - low
    rng > 0 ? math.abs(close - open) / rng : 0.0

f_findInt(int[] arr, int value) =>
    int result = -1
    sz = array.size(arr)
    if sz > 0
        for i = 0 to sz - 1
            if array.get(arr, i) == value
                result := i
    result

f_addReport(int y, int ym, float pnl) =>
    yi = f_findInt(yearKeys, y)
    if yi == -1
        array.push(yearKeys, y)
        array.push(yearPnl, pnl)
        array.push(yearTrades, 1)
    else
        array.set(yearPnl, yi, array.get(yearPnl, yi) + pnl)
        array.set(yearTrades, yi, array.get(yearTrades, yi) + 1)

    mi = f_findInt(monthKeys, ym)
    if mi == -1
        array.push(monthKeys, ym)
        array.push(monthPnl, pnl)
        array.push(monthTrades, 1)
    else
        array.set(monthPnl, mi, array.get(monthPnl, mi) + pnl)
        array.set(monthTrades, mi, array.get(monthTrades, mi) + 1)

// ---------- Monthly regime ----------
ret20D = request.security(syminfo.tickerid, "D", close[1] / close[20] - 1.0, barmerge.gaps_off, barmerge.lookahead_off)
ret240D = request.security(syminfo.tickerid, "D", close[1] / close[240] - 1.0, barmerge.gaps_off, barmerge.lookahead_off)
adr20D = request.security(syminfo.tickerid, "D", ta.sma(high - low, 20)[1], barmerge.gaps_off, barmerge.lookahead_off)
regimeOk = ret20D >= ret20Min and ret240D >= ret240Min and adr20D >= adr20Min

// ---------- Daily stop and reports ----------
var float dayPnl = 0.0
var int lastClosedCount = 0

newKstDay = ta.change(f_kstDay()) != 0 or ta.change(f_kstMonth()) != 0 or ta.change(f_kstYear()) != 0
if newKstDay
    dayPnl := 0.0

if strategy.closedtrades > lastClosedCount
    for i = lastClosedCount to strategy.closedtrades - 1
        p = strategy.closedtrades.profit(i)
        dayPnl += p
        exitTime = strategy.closedtrades.exit_time(i)
        y = year(exitTime, "Asia/Seoul")
        m = month(exitTime, "Asia/Seoul")
        f_addReport(y, y * 100 + m, p)
    lastClosedCount := strategy.closedtrades

dayStopOk = dayPnl > -dayStop
canOpen = regimeOk and dayStopOk and strategy.position_size == 0

// ---------- Bands ----------
bb20Mid = ta.sma(close, 20)
bb20Std = ta.stdev(close, 20)
bb20Up = bb20Mid + 2.0 * bb20Std
bb20Dn = bb20Mid - 2.0 * bb20Std
bb44MidOpen = ta.sma(open, 4)
bb44StdOpen = ta.stdev(open, 4)
bb44UpOpen = bb44MidOpen + 4.0 * bb44StdOpen
bb44DnOpen = bb44MidOpen - 4.0 * bb44StdOpen

// ---------- Grid component ----------
var int gridDir = 0
var int gridBarsLeft = 0
var float gridEntry1 = na
var float gridStopPrice = na
var bool gridTrailing = false
var float gridTrailStop = na
var bool gridReduced = false

longBreak = close > bb20Up and close > bb44UpOpen
shortBreak = close < bb20Dn and close < bb44DnOpen

if allowGrid and regimeOk and f_inKstHours(gridStartHour, gridEndHour) and strategy.position_size == 0
    if longBreak
        gridDir := 1
        gridBarsLeft := pendingBars
        gridEntry1 := bb44DnOpen
        gridStopPrice := gridEntry1 - gridStop
        gridTrailing := false
        gridTrailStop := na
        gridReduced := false
    else if shortBreak
        gridDir := -1
        gridBarsLeft := pendingBars
        gridEntry1 := bb44UpOpen
        gridStopPrice := gridEntry1 + gridStop
        gridTrailing := false
        gridTrailStop := na
        gridReduced := false

if allowGrid and gridBarsLeft > 0 and strategy.position_size == 0
    if gridDir == 1
        strategy.entry("G1", strategy.long, limit=gridEntry1, comment="grid")
        strategy.entry("G2", strategy.long, limit=gridEntry1 - gridStep, comment="grid")
        strategy.entry("G3", strategy.long, limit=gridEntry1 - 2.0 * gridStep, comment="grid")
    if gridDir == -1
        strategy.entry("G1", strategy.short, limit=gridEntry1, comment="grid")
        strategy.entry("G2", strategy.short, limit=gridEntry1 + gridStep, comment="grid")
        strategy.entry("G3", strategy.short, limit=gridEntry1 + 2.0 * gridStep, comment="grid")
    gridBarsLeft -= 1
else if gridBarsLeft == 0 and strategy.position_size == 0
    strategy.cancel("G1")
    strategy.cancel("G2")
    strategy.cancel("G3")
    gridDir := 0

gridPos = strategy.position_size != 0 and gridDir != 0
if gridPos
    avg = strategy.position_avg_price
    posLong = strategy.position_size > 0
    hardStopHit = posLong ? low <= gridStopPrice : high >= gridStopPrice
    if hardStopHit
        strategy.close_all(comment="grid_stop")
        gridDir := 0
    else
        filledApprox = math.abs(strategy.position_size)
        if filledApprox >= 3 and not gridReduced
            recPrice = posLong ? avg + gridRecovery : avg - gridRecovery
            recHit = posLong ? high >= recPrice : low <= recPrice
            if recHit
                strategy.close("G1", qty_percent=50, comment="grid_reduce")
                strategy.close("G2", qty_percent=50, comment="grid_reduce")
                strategy.close("G3", qty_percent=50, comment="grid_reduce")
                gridReduced := true
                gridTrailing := true
                gridTrailStop := avg
        armHit = posLong ? close >= avg + gridArm : close <= avg - gridArm
        if armHit or gridReduced
            gridTrailing := true
            gridTrailStop := posLong ? math.max(nz(gridTrailStop, avg), avg, close - gridTrail) : math.min(nz(gridTrailStop, avg), avg, close + gridTrail)
        if gridTrailing
            strategy.exit("GX1", from_entry="G1", stop=gridTrailStop)
            strategy.exit("GX2", from_entry="G2", stop=gridTrailStop)
            strategy.exit("GX3", from_entry="G3", stop=gridTrailStop)

// ---------- Session 15m opening range retest component ----------
var float sessHigh = na
var float sessLow = na
var int sessBars = 0
var int sessDir = 0
var float sessLevel = na
var bool sessBreakoutSeen = false
var bool sessTraded = false

asiaReset = f_kstHour() == 8 and f_kstMinute() == 30
euReset = hour(time, "Europe/London") == 8 and minute(time, "Europe/London") == 0
nyReset = hour(time, "America/New_York") == 9 and minute(time, "America/New_York") == 30
sessionReset = asiaReset or euReset or nyReset

if sessionReset
    sessHigh := high
    sessLow := low
    sessBars := 1
    sessDir := 0
    sessLevel := na
    sessBreakoutSeen := false
    sessTraded := false
else if sessBars > 0 and sessBars < 3
    sessHigh := math.max(sessHigh, high)
    sessLow := math.min(sessLow, low)
    sessBars += 1

rangeReady = sessBars >= 3 and not na(sessHigh) and not na(sessLow)
bodyOk = f_bodyRatio() >= bodyMin
if allowSession and rangeReady and not sessBreakoutSeen
    if close > sessHigh and bodyOk
        sessDir := 1
        sessLevel := sessHigh
        sessBreakoutSeen := true
    else if close < sessLow and bodyOk
        sessDir := -1
        sessLevel := sessLow
        sessBreakoutSeen := true

if allowSession and canOpen and sessBreakoutSeen and not sessTraded
    longRetest = sessDir == 1 and low <= sessLevel
    shortRetest = sessDir == -1 and high >= sessLevel
    if longRetest
        risk = close - sessLow
        if risk > syminfo.mintick
            strategy.entry("S", strategy.long, comment="session")
            strategy.exit("SX", from_entry="S", stop=sessLow, limit=close + rr * risk)
            sessTraded := true
    if shortRetest
        risk = sessHigh - close
        if risk > syminfo.mintick
            strategy.entry("S", strategy.short, comment="session")
            strategy.exit("SX", from_entry="S", stop=sessHigh, limit=close - rr * risk)
            sessTraded := true

// ---------- Onebee approximation ----------
sma20 = ta.sma(close, 20)
sma120 = ta.sma(close, 120)
crossLong = ta.crossover(sma20, sma120)
crossShort = ta.crossunder(sma20, sma120)
prior60High = ta.highest(high[1], 60)
prior60Low = ta.lowest(low[1], 60)
rng = high - low
upperWick = high - math.max(open, close)
lowerWick = math.min(open, close) - low
upperWickRatio = rng > 0 ? upperWick / rng : 1.0
lowerWickRatio = rng > 0 ? lowerWick / rng : 1.0
onebeeKtr = ta.atr(onebeeAtrLen)

var int cycleDir = 0
var bool boxActive = false
var float boxHigh = na
var float boxLow = na
if crossLong
    cycleDir := 1
    boxActive := false
if crossShort
    cycleDir := -1
    boxActive := false

if not boxActive
    if cycleDir == 1 and close > prior60High and close > open and upperWickRatio <= 0.10
        boxActive := true
        boxHigh := high
        boxLow := low
    if cycleDir == -1 and close < prior60Low and close < open and lowerWickRatio <= 0.10
        boxActive := true
        boxHigh := high
        boxLow := low

bodyInBoxLong = math.min(open, close) >= boxLow and math.max(open, close) <= boxHigh and close > open
bodyInBoxShort = math.min(open, close) >= boxLow and math.max(open, close) <= boxHigh and close < open
onebeeLong = allowOnebee and canOpen and boxActive and cycleDir == 1 and low <= bb44DnOpen and bodyInBoxLong and onebeeKtr > 0
onebeeShort = allowOnebee and canOpen and boxActive and cycleDir == -1 and high >= bb44UpOpen and bodyInBoxShort and onebeeKtr > 0
if onebeeLong
    strategy.entry("O", strategy.long, comment="onebee")
    strategy.exit("OX", from_entry="O", stop=close - onebeeStopKtr * onebeeKtr, limit=close + onebeeTargetKtr * onebeeKtr)
    boxActive := false
if onebeeShort
    strategy.entry("O", strategy.short, comment="onebee")
    strategy.exit("OX", from_entry="O", stop=close + onebeeStopKtr * onebeeKtr, limit=close - onebeeTargetKtr * onebeeKtr)
    boxActive := false

// ---------- Visuals ----------
plot(regimeOk ? 1 : 0, "Regime OK", color=color.new(color.teal, 0), display=display.data_window)
plot(dayPnl, "KST day PnL", color=color.new(color.orange, 0), display=display.data_window)
plot(bb20Up, "BB20/2 Upper", color=color.new(color.gray, 70))
plot(bb20Dn, "BB20/2 Lower", color=color.new(color.gray, 70))
plot(bb44UpOpen, "BB4/4 Upper Open", color=color.new(color.red, 75))
plot(bb44DnOpen, "BB4/4 Lower Open", color=color.new(color.green, 75))
bgcolor(regimeOk ? color.new(color.teal, 93) : na)
bgcolor(not dayStopOk ? color.new(color.red, 88) : na)

// ---------- Yearly/monthly report tables ----------
var table yearTable = table.new(position.top_right, 3, 18, border_width=1)
var table monthTable = table.new(position.bottom_right, 3, 42, border_width=1)

if barstate.islast and showReport
    table.clear(yearTable, 0, 0, 2, 17)
    table.cell(yearTable, 0, 0, "Year", bgcolor=color.rgb(30, 41, 59), text_color=color.white)
    table.cell(yearTable, 1, 0, "Trades", bgcolor=color.rgb(30, 41, 59), text_color=color.white)
    table.cell(yearTable, 2, 0, "PnL", bgcolor=color.rgb(30, 41, 59), text_color=color.white)
    yRows = math.min(array.size(yearKeys), 17)
    if yRows > 0
        for i = 0 to yRows - 1
            pnl = array.get(yearPnl, i)
            table.cell(yearTable, 0, i + 1, str.tostring(array.get(yearKeys, i)))
            table.cell(yearTable, 1, i + 1, str.tostring(array.get(yearTrades, i)))
            table.cell(yearTable, 2, i + 1, str.tostring(pnl, "#.0"), text_color=pnl >= 0 ? color.green : color.red)

    table.clear(monthTable, 0, 0, 2, 41)
    table.cell(monthTable, 0, 0, "Month", bgcolor=color.rgb(30, 41, 59), text_color=color.white)
    table.cell(monthTable, 1, 0, "Trades", bgcolor=color.rgb(30, 41, 59), text_color=color.white)
    table.cell(monthTable, 2, 0, "PnL", bgcolor=color.rgb(30, 41, 59), text_color=color.white)
    totalMonths = array.size(monthKeys)
    mRows = math.min(totalMonths, monthRows)
    if mRows > 0
        start = math.max(0, totalMonths - mRows)
        for r = 0 to mRows - 1
            idx = start + r
            key = array.get(monthKeys, idx)
            pnl = array.get(monthPnl, idx)
            y = math.floor(key / 100)
            m = key % 100
            label = str.tostring(y) + "-" + str.tostring(m, "00")
            table.cell(monthTable, 0, r + 1, label)
            table.cell(monthTable, 1, r + 1, str.tostring(array.get(monthTrades, idx)))
            table.cell(monthTable, 2, r + 1, str.tostring(pnl, "#.0"), text_color=pnl >= 0 ? color.green : color.red)
